{Scl_export_offset 0}
// ============================================================
// OB82 - 诊断中断组织块
// 冷库温度控制系统 - S7-1200 冷库控制器
// ============================================================
// 功能:
//   当硬件模块发生诊断事件时由系统自动调用
//   (如: 模块故障/掉线/通道故障/断线检测)
//   在此设置系统诊断标志, 记录故障信息
// ============================================================

ORGANIZATION_BLOCK "OB82"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

   VAR_TEMP
      // OB82 事件信息
      IOstate           : Word;       // IO状态
      laddr             : Word;       // 逻辑地址
      channel           : Int;        // 通道号
   END_VAR

BEGIN

   // ================================================================
   // 1. 读取诊断信息
   //    OB82 提供故障模块的逻辑地址和状态
   // ================================================================
   // 实际使用 #IOstate 和 #laddr 判断哪个模块故障

   // ================================================================
   // 2. 设置诊断报警标志
   //    标记到冷库数据块, 由WinCC读取报警
   // ================================================================
   // 模拟量模块故障 → 可能是温度传感器断线
   // 设置传感器故障标志 (具体通道判断根据实际配置)

   "DB_ColdRoom".bComm_Fault := FALSE;  // 模块故障不等于通信故障

   // ================================================================
   // 3. 记录诊断事件 (可选)
   //    写入诊断日志, 供维护人员分析
   // ================================================================
   // 可将 laddr 和 IOstate 写入循环缓冲区, 记录故障历史

END_ORGANIZATION_BLOCK


// ============================================================
// OB122 - I/O访问错误组织块
// 冷库温度控制系统 - S7-1200 冷库控制器
// ============================================================
// 功能:
//   当CPU访问I/O模块失败时由系统自动调用
//   (如: 模块被拔出/总线故障/地址错误)
//   在此进行错误处理, 防止程序崩溃
// ============================================================

ORGANIZATION_BLOCK "OB122"
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

   VAR_TEMP
      // OB122 事件信息
      swErrID           : Word;       // 错误ID
      iErrType          : Int;        // 错误类型
   END_VAR

BEGIN

   // ================================================================
   // 1. 分析错误类型
   //    Bit 7-8 of swErrID:
   //      00 = 读I/O错误
   //      01 = 写I/O错误
   //      10 = CPU功能错误
   //      11 = 寻址错误
   // ================================================================
   iErrType := swErrID AND 16#0300;
   iErrType := SHR(IN := iErrType, N := 8);

   // ================================================================
   // 2. I/O访问错误处理
   //    设置I/O故障标志, 系统进入降级运行模式
   //    降级模式: 保持最后有效输出, 报警等待维修
   // ================================================================

   // 设置通信/I/O故障标志
   "DB_ColdRoom".bComm_Fault := TRUE;

   // ================================================================
   // 3. 安全处理
   //    I/O故障时, 为安全起见停止该库所有压缩机
   //    (无法读取运行反馈, 继续运行有风险)
   // ================================================================
   // 注: 实际是否停机取决于安全策略
   //    也可以选择保持运行 (由OB1的逻辑决定)
   //    此处选择保守策略: 报警但保持运行 (由OB1的故障检测处理)

END_ORGANIZATION_BLOCK
